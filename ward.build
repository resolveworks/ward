[Unit]
Description=Build the Ward Arch Linux OCI image

[Build]
ImageTag=localhost/ward:latest
File=%h/Projects/ward/Containerfile
SetWorkingDirectory=%h/Projects/ward
IgnoreFile=%h/Projects/ward/.containerignore
Network=host
# The base is immutable by digest; reuse it and cached build layers when present.
Pull=missing

[Service]
Type=oneshot
RemainAfterExit=yes
TimeoutStartSec=30min
